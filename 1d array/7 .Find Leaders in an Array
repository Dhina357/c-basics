
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int rem(int arr[],int n){
     int max=arr[n-1];
    printf("%d ",max);
    for(int i=n-1;i>=0;i--){
        if(max<arr[i]){
           max=arr[i];
           printf("%d ",arr[i]);
        }
      
       
    }
  
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    
   rem(arr,n);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
