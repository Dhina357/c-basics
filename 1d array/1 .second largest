
#include <stdio.h>
#include <limits.h> 
int largest(int arr[],int n){
    int max=arr[0];
    int secm=INT_MIN;
    for(int i=1;i<n;i++){
        if(max<arr[i]){
            secm=max;
            max=arr[i];
        }
        else
        if(arr[i]>secm&&max!=arr[i]) secm=arr[i];
       
    }
    printf("\nthe second maximum is %d",secm);
    printf("\nthe  maximum is %d",max);
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    largest(arr,n);
    return 0;
}
