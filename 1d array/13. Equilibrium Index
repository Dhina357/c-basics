
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

int maxdiffer(int arr[],int n,int sum) {
	int l=0;
	int r=sum;
	for(int i=0; i<n; i++) {
	    if(l==r-arr[i])printf("yes %d",i);
	    l+=arr[i];
	    r-=arr[i];
	}
return 0;
}
int solve() {
	int n;
	scanf("%d",&n);
	int arr[n];
int sum=0;
	for(int i=0; i<n; i++) {
		scanf("%d",&arr[i]);
		sum+=arr[i];

	}
maxdiffer(arr,n,sum);

	return 0;
}

int main()
{
	solve();
	printf("\nHello World");

	return 0;
}
