
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int compare(const void *a,const void *b){
    return (*(int*)a-*(int*)b);
}
int freq(int arr[],int n){
     int i=0;
     while(i<n){
         int count=1;
         while(i+1<n&&arr[i+1]==arr[i]){
             count++;
             i++;
         }
         
         printf("\n%d->%d",arr[i],count);
         i++;
     }
  
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    qsort(arr,n,sizeof(int),compare);
    
   freq(arr,n);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
