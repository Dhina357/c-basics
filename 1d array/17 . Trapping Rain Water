
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 

int check(int arr[],int n){
    int left=0,right=n-1;
    int sum=0,max=0;
    while(left<right){
        int width=right-left;
        int height=arr[left]>arr[right]?arr[right]:arr[left];
        sum=width*height;
        if(sum>max)max=sum;
        if(arr[left]>arr[right])right--;
        else left++;
    }
printf("%d",max);
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
   
    
  check(arr,n);
   
   return 0;
}

