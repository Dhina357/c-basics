int check(int arr[],int n){
    //qsort(arr,n,sizeof(struct interval),compare);
    int m=arr[0];
    int maxx=arr[0];
    int min=arr[0];
for(int i=1;i<n;i++){
    if(arr[i]<0){
        int temp=maxx;
        maxx=min;
        min=temp;
    }
    maxx=(arr[i]>arr[i]*maxx)?arr[i]:arr[i]*maxx;
    min=(arr[i]<arr[i]*min)?arr[i]:arr[i]*min;
    if(m<maxx)m=maxx;
}
printf("%d",m);
return 0;
}
