
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int rem(int arr[],int n){
    int count =1;
    for(int i=0;i<n;i++){
        if(arr[i]!=arr[i+1]){
            arr[count++]=arr[i+1];
            
            
        }
    }
    for(int i=0;i<count-1;i++){
        printf("%d ",arr[i]);
    }
    
   
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    
   rem(arr,n);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
