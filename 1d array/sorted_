
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int sorted(int arr[],int n){
    int count=0;
    for(int i=1;i<n;i++){
        if(arr[i]<arr[i-1]){
            count=1;
            break;
            }
        
    }
    if(count==0)
        printf("Yes");
    else
    printf("No");
   
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
   sorted(arr,n);
    return 0;
}
int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
