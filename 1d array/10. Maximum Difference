
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 

int maxdiffer(int arr[],int n){
     int min=arr[0];
     int maxd=arr[1]-arr[0];
    for(int i=0;i<n;i++){
        if(arr[i]-min>maxd)maxd=arr[i]-min;
        if(arr[i]<min)min=arr[i];
    }
         printf("\n%d",maxd);
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
     
 
   maxdiffer(arr,n);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
