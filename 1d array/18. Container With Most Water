
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 

int check(int arr[],int n){
    int left[n],right[n];
    left[0]=arr[0];
    for(int i=1;i<n;i++){
        left[i]=(arr[i]>left[i-1]?arr[i]:left[i-1]);
    }
    right[n-1]=arr[n-1];
     for(int i=n-2;i>=0;i--){
        right[i]=(arr[i]>right[i+1]?arr[i]:right[i+1]);
    }
    int sum=0;
    for(int i=0;i<n;i++){
        int a=(left[i]>right[i]?right[i]:left[i]);
        sum+=a-arr[i];
         printf("%d ",sum);
    }
    printf("%d ",sum);

    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
   
    
  check(arr,n);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
