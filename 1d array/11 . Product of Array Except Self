
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 

int maxdiffer(int arr[],int n,int prod){
     
    for(int i=0;i<n;i++){
       printf("%d ",prod/arr[i]);
    }
         
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    int prod=1;
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
        prod*=arr[i];
    }
     
 
   maxdiffer(arr,n,prod);
   
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
