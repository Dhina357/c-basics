
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int movzero(int arr[],int n){
    
    int *ans=(int *)calloc(n,sizeof(int));
   int count=0;
    for(int i=0;i<n;i++){
        if(arr[i]!=0){
            ans[count++]=arr[i];
            }
        
    }
    for(int i=0;i<n;i++){
        printf("%d ",ans[i]);
    }
   
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    movzero(arr,n);
    return 0;
}
int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
