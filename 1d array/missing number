
#include <stdio.h>
#include <stdlib.h>
#include <limits.h> 
int missingnumber(int arr[],int n){
    int count=1;
    for(int i=0;i<n-1;i++){
        if((arr[i+1]!=arr[i]+1)&&arr[i]<n){
            count=arr[i]+1;
           
            break;
            }
        
    }
    printf("%d",count);
   
    return 0;
}
int solve(){
    int n;
    scanf("%d",&n);
    int arr[n-1];
    for(int i=0;i<n-1;i++){
        scanf("%d",&arr[i]);
    }
   missingnumber(arr,n);
   return 0;
}

int main()
{
    solve();
    printf("\nHello World");

    return 0;
}
