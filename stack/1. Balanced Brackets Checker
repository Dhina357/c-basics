#include <stdio.h>
#include<stdlib.h>
struct stack {
	char val;
	struct stack *next;
};
typedef struct stack s1;
s1 *top=NULL;
int push(char data) {
	s1 *newNode=(s1*)malloc(sizeof(s1));
	newNode->val=data;
	newNode->next=NULL;
	if(top==NULL) {
		top=newNode;
	}
	else {
		newNode->next=top;
		top=newNode;

	}
	return 0;
}
int pop() {
	top=top->next;
	return 0;
}
