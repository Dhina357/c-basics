int check(char *arr) {
    int flag=1;
     for(int i=0; arr[i]!='\0'; i++) {
	    if(arr[i]=='('||arr[i]=='['||arr[i]=='{'){	
		          push(arr[i]);
	    }
	    else if ((arr[i]==')'&&top->val!='(')||(arr[i]==']'&&top->val!='[')||(arr[i]=='}'&&top->val!='{')){
	        printf("Not a Valid ....");
	        flag=0;
	        break;
	    }
	    else pop();
	}
	if(flag==1)printf("Valid....");
	return 0;
}
int solve() {

	char *name=(char*)malloc(100000);
	scanf("%s",name);

	
	
	check(name);
	return 0;
}
