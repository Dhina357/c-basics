#include <stdio.h>
#include <stdlib.h>
#include <string.h>
struct queue{
    int data;
    struct queue *next;
}*rear=NULL,*front=NULL;
int queueSize=0;
int reverse(int k){
    struct queue *current=front;
   
    struct queue *prev =NULL;
    int i=0;
    while(i<k){
        struct queue *temp=current->next;
        current->next=prev;
        prev=current;
        current=temp;
        i++;
    }
    front->next=current;
    front=prev;
    
    return 0;
}
int size() {
	return queueSize;

}
int enqueue(int val) {
    struct queue *temp=(struct queue*)malloc(sizeof(struct queue));
    temp->data=val;
    temp->next=NULL;

	if(rear==NULL) {
		rear=front=temp;
	
	}
	else {
	rear->next=temp;
	rear=temp;
	}
	return 0;
}
