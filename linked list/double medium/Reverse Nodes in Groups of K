#include <stdio.h>
#include<stdlib.h>
struct node {
	struct node *prev;
	char *data;
	struct node *next;
}*head=NULL;
struct node *reverse(struct node *tail) {
	struct node* temp=NULL;
	struct node *current=tail;

	while(current!=NULL) {

		temp=current->prev;
		current->prev=current->next;
		current->next=temp;;


		current=current->prev;

	}
	if(temp!=NULL) {
		return temp->prev;
	}

	return tail;

}
int append(char *name) {
	struct node *newNode=(struct node*)malloc(sizeof(struct node));
	newNode->prev=NULL;
	newNode->data=name;
	newNode->next=NULL;
	if(head==NULL) {
		head=newNode;
	}
	else {
		struct node *lastNode=head;
		while(lastNode->next!=NULL) {
			lastNode=lastNode->next;

		}
		lastNode->next=newNode;
		newNode->prev=lastNode;
	}
	return 0;
}


int display() {
	struct node *temp=head;
	while(temp!=NULL) {

		printf("%s ",temp->data);
		temp=temp->next;
	}
	printf("\n");
	return 0;
}
int check(int key) {
	struct node* temp=head;
	struct node *last=NULL;
	struct node* dummy=head;

	int count=1;
	while(temp!=NULL) {
		struct node *nextitr=temp->next;
		if(count==key) {

			temp->next=NULL;
			struct node *ptr=reverse(dummy);
			if(last==NULL) 	{
				head=ptr;
				ptr->prev=NULL;
			}
			else {
				last->next=ptr;
				ptr->prev=last;
			}
			dummy->next=nextitr;
			if(nextitr != NULL) {
				nextitr->prev = dummy; // FIX 2: Connect backward pointer link
			}
			last=dummy;
count=0;
			dummy=nextitr;
		}
		count++;

		temp=nextitr;

	}
	return 0;
}
int solve() {
	int n;
	scanf("%d",&n);
	for(int i=0; i<n; i++) {
		char *name=(char*)malloc(100+1);
		scanf("%s",name);
		append(name);
	}
	display();


	int key;
	scanf("%d",&key);
	check(key);
	display();
	return 0;
}
int main() {
	solve();
	return 0;

}
