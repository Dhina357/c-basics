#include <stdio.h>
#include<stdlib.h>
struct node{
    struct node *prev;
     char *data;
    struct node *next;
}*head=NULL;

int append(char *name){
    struct node *newNode=(struct node*)malloc(sizeof(struct node));
    newNode->prev==NULL;
    newNode->data=name;
    newNode->next=NULL;
    if(head==NULL){
        head=newNode;
    }
    else{
        head->prev=newNode;
        newNode->next=head;
        head=newNode;
    }
    return 0;
}


int display(){
    struct node *temp=head;
    
   
    while(temp!=NULL){
        printf("%s ",temp->data);
        temp=temp->next;
    }
    return 0;
}
int solve(){
     int n;
     scanf("%d",&n);
     for(int i=0;i<n;i++){
   char *name=(char*)malloc(100+1);
     scanf("%s",name);
    append(name);
      }
      display();
      
      
     return 0;
}
int main(){
    solve();
    return 0;
    
}
