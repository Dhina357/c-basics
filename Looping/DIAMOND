#include<stdio.h>
int pattern(int a) {
	int b=(a/2)+1;
	for(int i=1; i<=a; i++) {
	    for(int k=1;k<=a-i;k++){
	        printf(" ");
	    }
		for(int j=1; j<=i*2-1; j++) {
            if(i==a||j==a)printf("*");
				else  printf("*");
		}
		printf("\n");
	}
	for(int i=a-1; i>=1; i--) {
	    for(int k=1;k<=a-i;k++){
	        printf(" ");
	    }
		for(int j=1; j<=i*2-1; j++) {
            if(i==a||j==a)printf("*");
				else  printf("*");
		}
		printf("\n");
	}
		
	return 0;
}
int solve() {
	int n,count;
	scanf("%d%n",&n,&count);
	pattern(n);

	return 0;
}
int main() {
	solve();
	return 0;
}