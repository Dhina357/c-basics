
#include <stdio.h>
int power(int a,int b) {
	int ans=1;
	while(b>0) {
		if((b&1)==1)ans*=a;
		a*=a;
		b>>=1;
	}
	return ans;
}
int main()
{
	int count,n;
	scanf("%d%n",&n,&count);
	int ams=0,b=n;
	while(n!=0) {
		ams+=power(n%10,count);
		n/=10;
		printf("The amstrong num:%d\n",ams);
	}
	printf("\nThe amstrong num:%d",ams);
	if(ams==b)
		printf("\nit is amstrong");
	else
		printf("\nit is not amstrong");
	return 0;
}