#include<stdio.h>
#include<limits.h>
#include<stdlib.h>
struct node {
	int val;
	struct node *ln,*rn;
}*root=NULL;
struct node *queue[100];
int rear=-1,front=-1;
void append(int data) {
	struct node *newNode=(struct node*)malloc(sizeof(struct node));
	newNode->val=data;
	newNode->ln=NULL;
	newNode->rn=NULL;
	if(root==NULL) {
		root=newNode;
		
		front++;
		rear++;
		queue[front]=newNode;
	} else {
		struct node *temp=queue[front];
		while(1) {
			if(temp->ln==NULL) {
				temp->ln=newNode;
				queue[++rear]=newNode;
				break;
			} else if(temp->rn==NULL) {
				temp->rn=newNode;
				queue[++rear]=newNode;
				break;
			} else {
				temp=queue[++front];
			}
		}
	}
}
void inorder(struct node *temp){
    if(temp!=NULL){
        inorder(temp->ln);
        printf("%d ",temp->val);
        inorder(temp->rn);
    }
    
}
void preorder(struct node *temp){
      if(temp!=NULL){
          printf("%d ",temp->val);
        preorder(temp->ln);
       
        preorder(temp->rn);
    }
}
void postorder(struct node *temp){
      if(temp!=NULL){
    postorder(temp->ln);
        
        postorder(temp->rn);
        printf("%d ",temp->val);
    }
}
int main()
{
	int n;
	scanf("%d",&n);
	for(int i=0; i<n; i++) {
		int a;
		scanf("%d",&a);
		append(a);
	}
	printf("\ninorder ");
	inorder(root);
		printf("\npreorder ");
	preorder(root);
		printf("\npostorder ");
	postorder(root);

	return 0;
}
