int check(int* arr1,int n,int k){
    int sum=0;
    int max=0;
    int l=0;
for(int r=0;r<n;r++){
     sum+=arr1[r];
    while(r-l+1>k){
        sum-=arr1[l];
        l++;
    }
    if(max<sum)max=sum;
}
printf("%d",max);
    return 0;
   
}
