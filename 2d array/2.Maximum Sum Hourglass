#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int max_sum = -2e9;

    for (int i = 0; i <= n - 3; i++) {
        for (int j = 0; j <= m - 3; j++) {
            int current_sum = matrix[i][j] + matrix[i][j+1] + matrix[i][j+2]
                              + matrix[i+1][j+1]
                              + matrix[i+2][j] + matrix[i+2][j+1] + matrix[i+2][j+2];
            if (current_sum > max_sum) {
                max_sum = current_sum;
            }
        }
    }

    printf("%d\n", max_sum);
    return 0;
}
