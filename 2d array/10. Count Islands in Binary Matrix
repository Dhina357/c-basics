#include <stdio.h>

int n, m;
int matrix[100][100];

void dfs(int r, int c) {
    if (r < 0 || r >= n || c < 0 || c >= m || matrix[r][c] != 1) {
        return;
    }
    matrix[r][c] = 0;
    dfs(r - 1, c);
    dfs(r + 1, c);
    dfs(r, c - 1);
    dfs(r, c + 1);
}

int main() {
    if (scanf("%d %d", &n, &m) != 2) return 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int count = 0;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            if (matrix[i][j] == 1) {
                count++;
                dfs(i, j);
            }
        }
    }

    printf("%d\n", count);
    return 0;
}
