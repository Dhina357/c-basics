#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[1000][1000];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int q;
    if (scanf("%d", &q) != 1) return 0;

    while (q--) {
        int target;
        scanf("%d", &target);
        
        int r = 0;
        int c = m - 1;
        int found = 0;

        while (r < n && c >= 0) {
            if (matrix[r][c] == target) {
                found = 1;
                break;
            } else if (matrix[r][c] > target) {
                c--;
            } else {
                r++;
            }
        }

        if (found) {
            printf("FOUND\n");
        } else {
            printf("NOT FOUND\n");
        }
    }

    return 0;
}
