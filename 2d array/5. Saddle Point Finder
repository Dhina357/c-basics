#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int found = 0;
    for (int i = 0; i < n; i++) {
        int min_row = matrix[i][0];
        int col_ind = 0;
        for (int j = 1; j < m; j++) {
            if (matrix[i][j] < min_row) {
                min_row = matrix[i][j];
                col_ind = j;
            }
        }

        int is_saddle = 1;
        for (int k = 0; k < n; k++) {
            if (matrix[k][col_ind] > min_row) {
                is_saddle = 0;
                break;
            }
        }

        if (is_saddle) {
            printf("%d\n", min_row);
            found = 1;
        }
    }

    if (!found) {
        printf("-1\n");
    }

    return 0;
}
