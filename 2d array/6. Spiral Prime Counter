#include <stdio.h>

int is_prime(int num) {
    if (num <= 1) return 0;
    if (num <= 3) return 1;
    if (num % 2 == 0 || num % 3 == 0) return 0;
    for (int i = 5; i * i <= num; i += 6) {
        if (num % i == 0 || num % (i + 2) == 0) return 0;
    }
    return 1;
}

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int count = 0;
    int top = 0, bottom = n - 1;
    int left = 0, right = m - 1;

    while (top <= bottom && left <= right) {
        for (int i = left; i <= right; i++) {
            if (is_prime(matrix[top][i])) {
                count++;
            }
        }
        top++;

        for (int i = top; i <= bottom; i++) {
            if (is_prime(matrix[i][right])) {
                count++;
            }
        }
        right--;

        if (top <= bottom) {
            for (int i = right; i >= left; i--) {
                if (is_prime(matrix[bottom][i])) {
                    count++;
                }
            }
            bottom--;
        }

        if (left <= right) {
            for (int i = bottom; i >= top; i--) {
                if (is_prime(matrix[i][left])) {
                    count++;
                }
            }
            left++;
        }
    }

    printf("%d\n", count);
    return 0;
}
