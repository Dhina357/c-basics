#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[100][100];
    int row_strength[100] = {0};
    int col_strength[100] = {0};

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
            row_strength[i] += matrix[i][j];
            col_strength[j] += matrix[i][j];
        }
    }

    int max_strength = 0;

    for (int i = 0; i < n; i++) {
        if (row_strength[i] > max_strength) {
            max_strength = row_strength[i];
        }
    }

    for (int j = 0; j < m; j++) {
        if (col_strength[j] > max_strength) {
            max_strength = col_strength[j];
        }
    }

    printf("%d\n", max_strength);

    return 0;
}
