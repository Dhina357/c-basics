#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;
    
    int a[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    
    int temp = a[0][0];
    
    for (int i = 0; i < n - 1; i++) {
        a[i][0] = a[i + 1][0];
    }
    
    for (int j = 0; j < m - 1; j++) {
        a[n - 1][j] = a[n - 1][j + 1];
    }
    
    for (int i = n - 1; i > 0; i--) {
        a[i][m - 1] = a[i - 1][m - 1];
    }
    
    for (int j = m - 1; j > 1; j--) {
        a[0][j] = a[0][j - 1];
    }
    
    a[0][1] = temp;
    
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            printf("%d ", a[i][j]);
        }
        printf("\n");
    }
    
    return 0;
}
