#include <stdio.h>

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int matrix[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int max_match = 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            int current_match = 0;
            for (int k = 0; k < n; k++) {
                if (matrix[i][k] == matrix[k][j]) {
                    current_match++;
                }
            }
            if (current_match > max_match) {
                max_match = current_match;
            }
        }
    }

    printf("%d\n", max_match);
    return 0;
}
