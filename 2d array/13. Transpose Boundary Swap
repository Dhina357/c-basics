#include <stdio.h>

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int matrix[100][100];
    int trans[100][100];

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
            trans[j][i] = matrix[i][j];
        }
    }

    for (int j = 0; j < n; j++) {
        int temp = trans[0][j];
        trans[0][j] = trans[n - 1][j];
        trans[n - 1][j] = temp;
    }

    for (int i = 1; i < n - 1; i++) {
        int temp = trans[i][0];
        trans[i][0] = trans[i][n - 1];
        trans[i][n - 1] = temp;
    }

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", trans[i][j]);
        }
        printf("\n");
    }

    return 0;
}
