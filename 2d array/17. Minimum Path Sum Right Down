#include <stdio.h>

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    int matrix[100][100];
    int dp[100][100];

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    dp[0][0] = matrix[0][0];

    for (int j = 1; j < m; j++) {
        dp[0][j] = dp[0][j - 1] + matrix[0][j];
    }

    for (int i = 1; i < n; i++) {
        dp[i][0] = dp[i - 1][0] + matrix[i][0];
    }

    for (int i = 1; i < n; i++) {
        for (int j = 1; j < m; j++) {
            int min_prev = (dp[i - 1][j] < dp[i][j - 1]) ? dp[i - 1][j] : dp[i][j - 1];
            dp[i][j] = min_prev + matrix[i][j];
        }
    }

    printf("%d\n", dp[n - 1][m - 1]);

    return 0;
}
